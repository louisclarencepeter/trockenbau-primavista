# Trockenbau Prima Vista — Netlify env vars
#
# How to use:
# 1. Copy this file to `.env` and fill in real values (kept locally; gitignored).
# 2. In Netlify: Site settings -> Environment variables -> "Import from a .env file"
#    and paste the contents of your `.env`. Set scope to "All scopes" so the
#    functions can read them at runtime.
# 3. Trigger a redeploy after adding/changing values.

# -- Email (Resend) -----------------------------------------------------------
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Sender shown to the recipient. Must be on a domain verified in Resend.
EMAIL_FROM="Trockenbau Prima Vista <info@trockenbau-primavista.ch>"

# Where customer replies should land (Reply-To header on the confirmation email).
EMAIL_REPLY_TO=info@trockenbau-primavista.ch

# Internal mailbox that receives every form submission. Must be able to RECEIVE
# mail (the apex MX must point to mx.hover.com.cust.hostedemail.com).
EMAIL_NOTIFICATION_TO=info@trockenbau-primavista.ch

# Optional BCC on the internal notification (e.g. admin@...). Leave blank to skip.
EMAIL_NOTIFICATION_BCC=

# Set to "true" to send the customer confirmation email. If "false", only the
# internal notification is sent (form still succeeds).
EMAIL_CONFIRMATIONS_ENABLED=true

# -- Chatbot (OpenAI) ---------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key

# -- Google Reviews -----------------------------------------------------------
GOOGLE_PLACE_ID=your-google-place-id
GOOGLE_PLACES_API_KEY=your-google-places-api-key
